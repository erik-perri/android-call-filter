<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.MODIFY_PHONE_STATE"
        android:maxSdkVersion="19"
        tools:ignore="ProtectedPermissions" />
    <!-- TelecomManager.acceptRingingCall()/endCall(). On API 28 this is how calls are blocked;
         on API 29+ blocking happens in the screening service and this only powers the
         answer-then-hang-up action. -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
    <uses-permission
        android:name="android.permission.CALL_PHONE"
        android:maxSdkVersion="28" />
    <!-- AudioManager.setMicrophoneMute(): keeps the caller from hearing the room during the
         brief connected moment of the answer-then-hang-up action. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- On API 28 this enriches the PHONE_STATE broadcast with the caller number. On API 29+ it is
         what makes that broadcast carry EXTRA_INCOMING_NUMBER, which CallReceiver needs to match the
         ringing call to the right answer-then-hang-up mark; without it the action degrades to block. -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Delivery of the PHONE_STATE ringing broadcast to CallReceiver. Below API 29 that
         broadcast drives all call filtering; on API 29+ filtering happens in the screening
         service and the receiver only performs the answer-then-hang-up handoff. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:name=".CallFilterApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="GoogleAppIndexingWarning">

        <activity android:name=".ui.loglist.LogListActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.rulelist.RuleListActivity"
            android:label="@string/action_rules">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.loglist.LogListActivity" />
        </activity>

        <receiver android:name=".CallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <service
            android:name="com.novyr.callfilter.CallFilterService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>
    </application>
</manifest>
